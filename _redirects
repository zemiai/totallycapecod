# Root → serve the PWA. URL bar stays at /, but the content is the app.
# This makes the first-touch experience the live tide/beach data, not marketing.
/                  /app/index.html    200!

# Shareable marketing front door (ads, social bios, partner links). The app stays
# the homepage; this gives the pitch-first page its own public URL.
/welcome           /index.html        200
/welcome/          /index.html        200

# Keep /app and /app/ working too — for anyone who bookmarked or shared the old URL.
/app               /app/index.html    200!
/app/              /app/index.html    200!

# Founder admin dashboard (password-gated via ADMIN_KEY). Pretty URL → function.
# Query string (?key=…) is forwarded automatically.
/admin             /.netlify/functions/admin   200
/admin/            /.netlify/functions/admin   200

# Old paths kept for backwards compatibility.
/app.html          /                   301!
/index.html        /                   301!

# When the PWA is accessed via /app/ directly, its relative `data/foo.json`
# fetches resolve to /app/data/foo.json — rewrite those back to the real files.
/app/data/*        /data/:splat        200
/app/manifest.json /manifest.json      200
